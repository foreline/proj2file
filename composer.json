{
  "name": "foreline/proj2file",
  "description": "PHP Console application used to pack all project to one file.",
  "license": "MIT",
  "authors": [
    {
      "name": "Dima Simakin",
      "email": "dima@foreline.ru"
    }
  ],
  "minimum-stability": "dev",
  "require": {
    "php": ">=8.1",
    "symfony/console": "^6.4",
    "symfony/finder": "^6.4",
    "symfony/filesystem": "^6.4",
    "symfony/yaml": "^6.4",
    "symfony/config": "^6.4",
    "ext-mbstring": "*"
  },
  "require-dev": {
    "symfony/var-dumper": "^6.4",
    "phpstan/phpstan": "^1.10",
    "phpunit/phpunit": "10"
  },
  "autoload": {
    "psr-4": {
      "Foreline\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Foreline\\Tests\\": "tests/"
    }
  },
  "bin": [
    "proj2file"
  ],
  "scripts": {
    "phpstan": "vendor/bin/phpstan analyze -c phpstan.neon"
  }
}
