{
  "name": "foreline/proj2file",
  "description": "PHP Console application used to pack all project to one file.",
  "license": "MIT",
  "authors": [
    {
      "name": "Dima Simakin",
      "email": "dima@foreline.ru"
    }
  ],
  "minimum-stability": "dev",
  "require": {
    "php": ">8.0",
    "symfony/config": "*",
    "symfony/console": "*",
    "symfony/finder": "*",
    "symfony/filesystem": "*",
    "kevinlebrun/colors.php": "^1",
    "webmozart/assert": "^1.11",
    "ext-mbstring": "*"
  },
  "require-dev": {
    "symfony/var-dumper": "*"
  },
  "autoload": {
    "psr-4": {
      "Foreline\\": "src/"
    }
  },
  "bin": [
    "proj2file"
  ]
}
